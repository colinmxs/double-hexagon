# For local dev, leave VITE_API_BASE_URL unset — Vite proxy handles /api requests.
# To point directly at a deployed API Gateway, set:
# VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/api

# Set to 'false' to disable auth during local development
# VITE_AUTH_ENABLED=false
