# ==========================================================================
# Devcontainer environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==========================================================================

# GitHub — fine-grained PAT with read-only "Contents" permission
# Create at: https://github.com/settings/personal-access-tokens/new
# Scope: your repo, Permissions: Contents → Read-only
GH_TOKEN=

# AWS — read-only credentials
# Option A: IAM user with ReadOnlyAccess policy
# Option B: Temporary creds from `aws sts assume-role` (include session token)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
